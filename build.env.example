# 이미지 빌드/푸시 설정 (build_push.ps1 / build_push.sh 가 읽음)
# 실제 값은 build.env 로 복사해서 사용 (git 제외됨)
#   cp build.env.example build.env

# 컨테이너 레지스트리 주소 (예: Harbor)
REGISTRY=harbor.example.com

# Harbor 프로젝트(네임스페이스) 이름
REGISTRY_PROJECT=library

# 이미지 이름
IMAGE_NAME=ncp-server-manager

# 태그 (비우면 git short hash 사용, 없으면 latest)
IMAGE_TAG=
