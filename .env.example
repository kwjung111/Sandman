# 네이버 클라우드 API 인증 정보
NCP_ACCESS_KEY=your_access_key_here
NCP_SECRET_KEY=your_secret_key_here

# API 엔드포인트 (일반: ncloud.apigw.ntruss.com / 정부: ncloud.apigw.gov-ntruss.com)
NCP_API_URL=https://ncloud.apigw.gov-ntruss.com

# 업무 시간 설정 (24시간 형식)
WORK_START_HOUR=9
WORK_START_MINUTE=0
WORK_END_HOUR=18
WORK_END_MINUTE=0

# 주말 포함 여부 (true/false)
INCLUDE_WEEKENDS=false

# 서버 이름 필터 - 포함 (쉼표로 구분)
# 예: dev,test -> 이름에 'dev' 또는 'test'가 포함된 서버만 관리
SERVER_NAME_FILTER=dev,test

# 서버 이름 필터 - 제외 (쉼표로 구분)
# 예: prod,backup -> 이름에 'prod' 또는 'backup'이 포함된 서버 제외
SERVER_NAME_EXCLUDE=prod,backup
